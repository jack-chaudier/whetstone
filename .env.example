# Optional server-side secrets. Never prefix these with NEXT_PUBLIC_.
# Copy this file to .dev.vars for the local Worker runtime only.
# GPT Sites production secrets are configured in Sites, not committed here.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=

# Required only for Grok subscription OAuth. Generate a random value of at least 32 characters.
# OAUTH_COOKIE_SECRET=
